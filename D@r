<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ma Page Professionnelle</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background-color: #f4f6f9;
            color: #333;
        }

        header {
            background: #0a3d62;
            color: white;
            padding: 20px 0;
            text-align: center;
        }

        nav {
            margin-top: 10px;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
            font-weight: bold;
        }

        nav a:hover {
            text-decoration: underline;
        }

        .hero {
            padding: 60px 20px;
            text-align: center;
            background: linear-gradient(to right, #0a3d62, #3c6382);
            color: white;
        }

        .hero h1 {
            font-size: 40px;
            margin-bottom: 15px;
        }

        .section {
            padding: 50px 20px;
            max-width: 1000px;
            margin: auto;
        }

        .services {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            justify-content: center;
        }

        .card {
            background: white;
            padding: 25px;
            width: 280px;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            text-align: center;
        }

        .card h3 {
            margin-bottom: 10px;
            color: #0a3d62;
        }

        footer {
            text-align: center;
            padding: 20px;
            background: #0a3d62;
            color: white;
            margin-top: 40px;
        }

        @media (max-width: 768px) {
            .services {
                flex-direction: column;
                align-items: center;
            }

            .hero h1 {
                font-size: 28px;
            }
        }
    </style>
</head>
<body>

<header>
    <h2>Mon Entreprise</h2>
    <nav>
        <a href="#">Accueil</a>
        <a href="#">Services</a>
        <a href="#">Contact</a>
    </nav>
</header>

<section class="hero">
    <h1>Bienvenue sur ma page professionnelle</h1>
    <p>Innovation • Performance • Excellence</p>
</section>

<section class="section">
    <h2 style="text-align:center; margin-bottom:30px;">Nos Services</h2>
    <div class="services">
        <div class="card">
            <h3>Conseil</h3>
            <p>Accompagnement stratégique et technique adapté à vos besoins.</p>
        </div>
        <div class="card">
            <h3>Développement</h3>
            <p>Solutions modernes et optimisées pour vos projets digitaux.</p>
        </div>
        <div class="card">
            <h3>Maintenance</h3>
            <p>Suivi et optimisation continue de vos systèmes.</p>
        </div>
    </div>
</section>

<section class="section">
    <h2 style="text-align:center; margin-bottom:20px;">Contact</h2>
    <p style="text-align:center;">Email : contact@monentreprise.com</p>
</section>

<footer>
    &copy; 2026 Mon Entreprise - Tous droits réservés
</footer>

</body>
</html>
